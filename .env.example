# ellmos-stack Configuration
# Copy this to .env and fill in your values:
#   cp .env.example .env

# === n8n ===
# n8n >= 1.0 has no Basic Auth. Authentication happens via the owner account
# you create in the web UI on first start (port 5678 is bound to localhost --
# use an SSH tunnel, see README "Security Notes").
# Pin the image to a tested version before production use (default: latest)
# N8N_IMAGE_TAG=latest

# === Ollama ===
# Model to preload (default: qwen3:4b -- good balance of speed and quality)
OLLAMA_MODEL=qwen3:4b
# Max memory for Ollama container
OLLAMA_MEMORY_LIMIT=6G
# Base URL used by the service scripts (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434
# Pin the image to a tested version before production use (default: latest)
# OLLAMA_IMAGE_TAG=latest

# === KnowledgeDigest ===
# Web viewer port
KD_PORT=8787
# Summarization provider: ollama | anthropic | custom
KD_SUMMARY_PROVIDER=ollama
# Only needed if KD_SUMMARY_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# === Telegram Gateway ===
# Get a bot token from @BotFather on Telegram
RINNSAL_TELEGRAM_TOKEN=
# Your personal chat ID (send /start to @userinfobot to find it)
TELEGRAM_OWNER_CHAT_ID=
# Optional: URL to check if BACH (laptop) is reachable
# BACH_HEARTBEAT_URL=http://your-laptop:8888/ping

# === General ===
TZ=Europe/Berlin
